# This file is the template for the .env file. You should copy this file to .env and fill in the values.

# =========
# port
# This is the port that the server will listen on.
PORT=8000

# =========
# database
# This is the database connection string. It should be in the format:
#   postgresql://username:password@host:port/database
DATABASE_URL=postgres://postgres:@localhost:5432/kompagnon

# =========
# matching algorithm
# Configuration for the multi-criteria matching algorithm.
# All values have sensible defaults — only override what you need.

# Maximum distance (in km) between two points to be considered a match.
# Beyond this distance, the geographic score is 0 and no match is possible.
MATCH_MAX_DISTANCE_KM=5.0

# Distance (in km) below which the geographic score is 1.0 (perfect proximity).
MATCH_PERFECT_DISTANCE_KM=0.5

# Maximum time difference (in minutes) between departure times to be considered a match.
# Beyond this tolerance, the time score is 0 and no match is possible.
MATCH_TIME_TOLERANCE_MINUTES=30

# Minimum overall score (0.0 to 1.0) required to consider a pair as a valid match.
MATCH_MIN_SCORE=0.5

# Weight of the geographic proximity score (departure + arrival).
MATCH_WEIGHT_GEO=0.40

# Weight of the time compatibility score.
MATCH_WEIGHT_TIME=0.40

# Weight of the textual address match score.
MATCH_WEIGHT_ADDRESS=0.20