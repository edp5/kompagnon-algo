# Changelog

{% for version, release in ctx.history.released.items() %}
## {{ version.as_tag() }} ({{ release.tagged_date.strftime("%Y-%m-%d") }})

{# --- Breaking Changes --- #}
{%- set breaking = [] %}
{%- for type_, commits in release.elements.items() %}
  {%- for commit in commits %}
    {%- if commit.breaking_descriptions %}
      {%- set _ = breaking.append(commit) %}
    {%- endif %}
  {%- endfor %}
{%- endfor %}

{%- if breaking %}
### 💥 Breaking Changes
{%- for commit in breaking %}
  {%- for desc in commit.breaking_descriptions %}
- {{ desc | capitalize }} (`{{ commit.short_hash }}`)
  {%- endfor %}
{%- endfor %}

{% endif %}

{# --- Features --- #}
{%- if "feat" in release.elements %}
### 🚀 Features
{%- for commit in release.elements["feat"] %}
- {{ (commit.descriptions[0] if commit.descriptions else commit.message) | capitalize }} (`{{ commit.short_hash }}`)
{%- endfor %}

{% endif %}

{# --- Bug Fixes --- #}
{%- if "fix" in release.elements %}
### 🐛 Bug Fixes
{%- for commit in release.elements["fix"] %}
- {{ (commit.descriptions[0] if commit.descriptions else commit.message) | capitalize }} (`{{ commit.short_hash }}`)
{%- endfor %}

{% endif %}

{# --- Performance & Refactor & Docs --- #}
{%- for type_key, title in [("perf", "⚡ Performance Improvements"), ("refactor", "🏗️ Refactoring"), ("docs", "📚 Documentation"), ("revert", "⏪ Reverts")] %}
{%- if type_key in release.elements %}
### {{ title }}
{%- for commit in release.elements[type_key] %}
- {{ (commit.descriptions[0] if commit.descriptions else commit.message) | capitalize }} (`{{ commit.short_hash }}`)
{%- endfor %}

{% endif %}
{%- endfor %}

{# --- Maintenance --- #}
{%- set maintenance_commits = [] %}
{%- for type_key in ["chore", "ci", "build", "test", "style"] %}
  {%- if type_key in release.elements %}
    {%- for commit in release.elements[type_key] %}
      {%- set _ = maintenance_commits.append(commit) %}
    {%- endfor %}
  {%- endif %}
{%- endfor %}

{%- if maintenance_commits %}
### 🧰 Maintenance
{%- for commit in maintenance_commits %}
- {{ (commit.descriptions[0] if commit.descriptions else commit.message) | capitalize }} (`{{ commit.short_hash }}`)
{%- endfor %}

{% endif %}
{% endfor %}