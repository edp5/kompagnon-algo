{
  "branches": ["main"],

  "commit_parser": "conventional",

  "parse_commit_message": {
    "pattern": "^(?P<type>feat|fix|perf|revert|refactor|docs|chore|style|test)(?:\\((?P<scope>[^)]*?)\\))?(?P<breaking>!)?: (?P<message>.*)$",
    "commit_type_regex": "^(feat|fix|perf|revert|refactor|docs|chore|style|test)$",
    "default_bump": null
  },

  "commit_types": [
    {
      "type": "feat",
      "release": "minor",
      "section": "🚀 Features"
    },
    {
      "type": "breaking",
        "release": "major",
        "section": "💥 Breaking Changes"
    },
    {
      "type": "fix",
      "release": "patch",
      "section": "🐛 Bug Fixes"
    },
    {
      "type": "perf",
      "release": "patch",
      "section": "⚡ Performance Improvements"
    },
    {
      "type": "revert",
      "release": "patch",
      "section": "⏪ Reverts"
    },
    {
      "type": "refactor",
      "release": "patch",
      "section": "🏗️ Refactoring"
    },
    {
      "type": "docs",
      "release": "patch",
      "section": "📚 Documentation"
    },
    {
      "type": "chore",
      "release": false
    },
    {
      "type": "style",
      "release": false
    },
    {
      "type": "test",
      "release": false
    }
  ],

  "version_toml": ["pyproject.toml:project.version"],

  "build_command": "python -m pip install build && python -m build",

  "upload_to_pypi": false,
  "upload_to_release": true,

  "changelog_file": "CHANGELOG.md",

  "git_commit_message": "chore(release): {version}",

  "git_push": true,
  "git_tag": true,

  "allow_zero_version": false
}